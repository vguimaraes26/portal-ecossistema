# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=./data.json

# Backup
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_ENABLED=true

# Scheduler
SCHEDULER_ENABLED=true

# Newsletter
NEWSLETTER_RATE_LIMIT_SUBSCRIBE=1
NEWSLETTER_RATE_LIMIT_WINDOW=600000
NEWSLETTER_RATE_LIMIT_ADMIN=5
NEWSLETTER_RATE_LIMIT_ADMIN_WINDOW=60000

# Security
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
